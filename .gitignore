# ==========================================
# Dependencies
# ==========================================
# Blocks heavy package directories for both Backend and Frontend
node_modules/
jspm_packages/
web_stage/

# ==========================================
# Environment & Secrets
# ==========================================
# Prevents leaking API keys, database credentials, and session secrets
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env

# ==========================================
# Production Builds (Frontend)
# ==========================================
# Ignores compiled frontend assets (Vite/CRA)
dist/
build/
out/

# ==========================================
# Logs and Debugging
# ==========================================
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ==========================================
# System & Editor Files
# ==========================================
# OS generated files
.DS_Store
Thumbs.db

# IDEs and editors
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?